# Copia este archivo a ".env" y ajusta los valores antes de arrancar el servidor.

# Credenciales del único usuario admin (se usan solo la primera vez que se crea data/db.json).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-clave

# Cadena secreta para firmar la cookie de sesión. Usa un valor largo y aleatorio en producción.
SESSION_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio

PORT=4000
NODE_ENV=development
